{
  "kind": "collectionType",
  "collectionName": "todos",
  "info": {
    "singularName": "todo",
    "pluralName": "todos",
    "displayName": "Todo"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "isCompleted": {
      "type": "boolean",
      "default": false
    },
    "completed": {
      "type": "boolean",
      "default": false
    },
    "depth": {
      "type": "integer",
      "default": 0
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "todos"
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::todo.todo",
      "inversedBy": "children"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::todo.todo",
      "mappedBy": "parent"
    }
  }
}
